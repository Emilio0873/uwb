rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Règle demandée : Lecture publique, Ecriture interdite par défaut
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Note : Pour que l'inscription fonctionne, l'utilisateur doit pouvoir créer son profil
    match /profiles/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Règle pour les chats : l'utilisateur accède uniquement à ses propres conversations
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
